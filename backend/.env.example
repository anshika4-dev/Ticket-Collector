# Database connection (Supabase or any PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Gmail SMTP (use an App Password, not your main Gmail password)
# Get App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# Seat hold TTL in minutes (default: 10)
SEAT_HOLD_TTL_MINUTES=10

# Waitlist offer TTL in minutes (default: 15)
WAITLIST_OFFER_TTL_MINUTES=15

# Server port
PORT=3001

# Environment
NODE_ENV=development
